# SolFoundry Backend Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# ──── Required Secrets ─────────────────────────────────────────────

# Secret key for signing JWT tokens (min 32 chars)
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters-long

# GitHub OAuth application client secret
GITHUB_CLIENT_SECRET=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret for verifying GitHub webhook signatures
GITHUB_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/solfoundry

# ──── Optional Configuration ──────────────────────────────────────

# GitHub OAuth application client ID
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxxxxxx

# GitHub OAuth callback URL
GITHUB_REDIRECT_URI=https://solfoundry.org/auth/callback

# Solana RPC endpoint URL
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana treasury wallet public key
TREASURY_WALLET=AqqW7hFLau8oH8nDuZp5jPjM3EXUrD7q3SxbcNE8YTN1

# Redis connection URL for caching and rate limiting
REDIS_URL=redis://localhost:6379/0

# Enable authentication (true/false)
AUTH_ENABLED=true

# Enforce HTTPS via HSTS headers (true/false)
ENFORCE_HTTPS=true

# Maximum request body size in bytes
MAX_REQUEST_BODY_SIZE=1048576

# ──── Rate Limiting ───────────────────────────────────────────────

# Rate limit for anonymous users (requests/minute)
RATE_LIMIT_ANONYMOUS=30

# Rate limit for authenticated users (requests/minute)
RATE_LIMIT_AUTHENTICATED=120

# Rate limit for admin users (requests/minute)
RATE_LIMIT_ADMIN=300

# ──── Database Pool ───────────────────────────────────────────────

# Database connection pool size
DB_POOL_SIZE=5

# Maximum pool overflow connections
DB_POOL_MAX_OVERFLOW=10

# Echo SQL queries to logs (true/false, dev only)
SQL_ECHO=false

# ──── Backup Configuration ────────────────────────────────────────

# Directory for PostgreSQL backup files
BACKUP_DIR=/var/backups/solfoundry

# Number of days to retain backup files
BACKUP_RETENTION_DAYS=30

# ──── Security Hardening ──────────────────────────────────────────

# Max failed login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Base lockout duration in seconds (15 minutes)
LOCKOUT_DURATION_SECONDS=900

# Maximum concurrent sessions per user
MAX_SESSIONS_PER_USER=5

# Escrow max transaction age in seconds
ESCROW_TX_MAX_AGE=300

# Max concurrent escrow operations
ESCROW_MAX_CONCURRENT=10
